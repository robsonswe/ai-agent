# =============================================================================
# LLM PROVIDER CONFIGURATION
# Choose ONE section below and uncomment it. 
# Make sure only one LLM_PROVIDER is active at a time.
# =============================================================================

# --- OPTION 1: OPENROUTER (Recommended for multiple models) ---
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-your-api-key-here
LLM_MODEL=anthropic/claude-3-5-sonnet
LLM_BASE_URL=https://openrouter.ai/api/v1
# Optional: App attribution for OpenRouter analytics
# OPENROUTER_APP_URL=https://yourdomain.com
# OPENROUTER_APP_TITLE=Your App Name

# --- OPTION 2: ANTHROPIC (Native Claude) ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-api03-your-key
# LLM_MODEL=claude-3-5-sonnet-latest

# --- OPTION 3: GOOGLE GEMINI (Native) ---
# LLM_PROVIDER=gemini
# LLM_API_KEY=your-google-api-key
# LLM_MODEL=gemini-1.5-flash

# --- OPTION 4: OPENAI (Direct) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-proj-your-openai-api-key
# LLM_MODEL=gpt-4o-mini

# --- OPTION 5: OLLAMA (Local/Self-Hosted) ---
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1

# =============================================================================
# SKILLS & APPLICATION SETTINGS
# =============================================================================
SKILLS_DIR=skills
APP_ENV=development
LOG_LEVEL=INFO

# =============================================================================
# LOGFIRE OBSERVABILITY (Optional)
# =============================================================================
# Get token from: logfire auth
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=skill-agent
LOGFIRE_ENVIRONMENT=development
